# =============================================================================
# StreamFlix Backend — Variables d'environnement
# =============================================================================
# Copier ce fichier en .env.dev et remplir les valeurs

# --- Serveur ---
PORT=2000
GIN_MODE=debug                    # debug | release | test
ENVIRONMENT=development           # development | production

# --- Tokens API (OBLIGATOIRES) ---
REALDEBRID_TOKEN=your_realdebrid_token_here
TMDB_TOKEN=your_tmdb_bearer_token_here

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Logging ---
LOG_LEVEL=debug                   # debug | info | warn | error

# --- Scraper ---
USER_AGENT=StreamFlix/1.0
HTTP_TIMEOUT_SECONDS=10

# --- Cache ---
CACHE_TTL_MINUTES=5
